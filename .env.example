# Másold .env-be és töltsd ki a végrehajtás során (NE kerüljön gitbe).

# --- Adatbázis (3. kártyától) ---
POSTGRES_DB=nexa
POSTGRES_USER=nexa
POSTGRES_PASSWORD=change-me

# --- JWT (3. kártya) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Objektumtároló R2/S3 (6. kártya) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nexa-media

# --- Paddle előfizetés (14. kártya) ---
# Sandboxban fejlesztünk; éles: PADDLE_ENV=production és PADDLE_API_URL=https://api.paddle.com
PADDLE_ENV=sandbox
PADDLE_API_URL=https://sandbox-api.paddle.com
PADDLE_API_KEY=                # Paddle > Developer tools > Authentication (szerver-oldali kulcs)
PADDLE_CLIENT_TOKEN=           # Paddle > Developer tools > Authentication (publikus kliens-token)
PADDLE_WEBHOOK_SECRET=         # Paddle > Notifications > a webhook-célpont titkos kulcsa (pdl_ntfset_...)
PADDLE_PRICE_MONTHLY=          # a havi csomag price ID-ja (pri_...), 14 napos trial beállítva rá
PADDLE_PRICE_ANNUAL=           # az éves csomag price ID-ja (pri_...), 14 napos trial beállítva rá
