# Másold .env-be és töltsd ki a végrehajtás során (NE kerüljön gitbe).

# --- Adatbázis (3. kártyától) ---
POSTGRES_DB=nexa
POSTGRES_USER=nexa
POSTGRES_PASSWORD=change-me

# --- JWT (3. kártya) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Objektumtároló R2/S3 (6. kártya) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nexa-media

# --- Paddle (14. kártya) ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
